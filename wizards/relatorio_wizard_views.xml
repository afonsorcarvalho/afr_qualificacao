<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Form do wizard de novo relatório parcial -->
    <record id="view_afr_qualificacao_os_relatorio_wizard_form" model="ir.ui.view">
        <field name="name">afr.qualificacao.os.relatorio.wizard.form</field>
        <field name="model">afr.qualificacao.os.relatorio.wizard</field>
        <field name="arch" type="xml">
            <form string="Novo relatório parcial">
                <sheet>
                    <group>
                        <group string="Intervalo">
                            <field name="os_id" readonly="1"/>
                            <field name="data_inicio"/>
                            <field name="data_fim"
                                   placeholder="Preenche depois ao concluir"/>
                        </group>
                        <group string="Equipe">
                            <field name="tecnico_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                    <group string="Descrição">
                        <field name="descricao" nolabel="1"
                               placeholder="Ex.: das 08h às 12h realizando primeiro ciclo vazio da QD autoclave AC-01."/>
                    </group>
                    <notebook>
                        <page string="Cobertura técnica">
                            <group>
                                <field name="cycle_ids" widget="many2many_tags"/>
                                <field name="malha_ids" widget="many2many_tags"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <footer>
                    <button name="action_create" type="object"
                            string="Criar relatório" class="btn-primary"/>
                    <button special="cancel" string="Cancelar" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
