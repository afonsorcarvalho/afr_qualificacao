<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- F8.4 — Configurador guiado multi-step (Escopo → Opcionais →
         Blocos → Revisão). Navegação por step + botões Voltar/Próximo. -->
    <record id="view_qualificacao_configurator_form" model="ir.ui.view">
        <field name="name">afr.qualificacao.configurator.form</field>
        <field name="model">afr.qualificacao.configurator</field>
        <field name="arch" type="xml">
            <form string="Configurador de Qualificações">
                <header>
                    <field name="step" widget="statusbar"
                           statusbar_visible="escopo,revisao"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="sale_order_id" readonly="1"/>
                            <field name="partner_id"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>

                    <!-- ETAPA 1 — ESCOPO -->
                    <div attrs="{'invisible': [('step', '!=', 'escopo')]}">
                        <group>
                            <field name="proposal_template_id"
                                   options="{'no_create': True}"/>
                        </group>
                        <div style="margin: 6px 0 10px 0;">
                            <button name="action_add_multiple_equipments"
                                    string="+ Vários Equipamentos"
                                    type="object"
                                    class="btn-secondary"/>
                            <button name="action_save_as_template"
                                    string="Salvar como Template"
                                    type="object"
                                    class="btn-secondary"/>
                        </div>
                        <field name="equipment_line_ids">
                            <form>
                                <header>
                                    <button name="action_duplicate"
                                            string="Duplicar"
                                            type="object"
                                            class="btn-secondary"/>
                                </header>
                                <sheet>
                                    <group>
                                        <group>
                                            <field name="equipment_id"
                                                   domain="[('client_id','=',parent.partner_id)]"
                                                   options="{'no_create': True}"/>
                                            <field name="equipment_category_id"/>
                                            <field name="config_template_id"
                                                   domain="['|',('equipment_category_id','=',equipment_category_id),('equipment_category_id','=',False),('active','=',True)]"
                                                   options="{'no_create': True}"/>
                                        </group>
                                        <group>
                                            <field name="do_qi"/>
                                            <field name="qi_part01_declined"
                                                   attrs="{'invisible': [('do_qi', '=', False)], 'readonly': [('do_qi', '=', False)]}"/>
                                            <field name="do_qo" invisible="1"/>
                                            <field name="do_qo_part01"/>
                                            <field name="qo_part01_declined"
                                                   attrs="{'invisible': [('do_qo_part01', '=', False)], 'readonly': [('do_qo_part01', '=', False)]}"/>
                                            <field name="do_qs"/>
                                            <field name="currency_id" invisible="1"/>
                                            <field name="subtotal"/>
                                            <field name="estimated_hours_total" readonly="1"/>
                                            <field name="work_hours_per_day"/>
                                            <field name="estimated_days_total" readonly="1"/>
                                        </group>
                                    </group>
                                    <notebook>
                                        <page string="Ciclos QO (sem carga)">
                                            <field name="qo_line_ids">
                                                <tree editable="bottom">
                                                    <field name="cycle_type_id"
                                                           domain="['|', ('equipment_category_id','=',parent.equipment_category_id), ('equipment_category_id','=',False), ('load_type','in',['vazio','sem_carga']), ('active','=',True)]"/>
                                                    <field name="description"/>
                                                    <field name="temperature"/>
                                                    <field name="duration"/>
                                                    <field name="load_type"/>
                                                    <field name="qty"/>
                                                    <field name="unit_price"/>
                                                    <field name="estimated_hours"/>
                                                    <field name="currency_id" invisible="1"/>
                                                    <field name="subtotal"/>
                                                </tree>
                                            </field>
                                        </page>
                                        <page string="Ciclos QD (com carga)">
                                            <field name="qd_line_ids">
                                                <tree editable="bottom">
                                                    <field name="cycle_type_id"
                                                           domain="['|', ('equipment_category_id','=',parent.equipment_category_id), ('equipment_category_id','=',False), ('load_type','=','com_carga'), ('active','=',True)]"/>
                                                    <field name="description"/>
                                                    <field name="temperature"/>
                                                    <field name="duration"/>
                                                    <field name="load_type"/>
                                                    <field name="qty"/>
                                                    <field name="unit_price"/>
                                                    <field name="estimated_hours"/>
                                                    <field name="currency_id" invisible="1"/>
                                                    <field name="subtotal"/>
                                                </tree>
                                            </field>
                                        </page>
                                        <page string="Malhas Calibração">
                                            <field name="calib_line_ids">
                                                <tree editable="bottom">
                                                    <field name="malha_type_id"
                                                           domain="['|',('equipment_category_id','=',parent.equipment_category_id),('equipment_category_id','=',False),('active','=',True)]"/>
                                                    <field name="sensor_kind_id"/>
                                                    <field name="description"/>
                                                    <field name="qty"/>
                                                    <field name="unit_price"/>
                                                    <field name="estimated_hours"/>
                                                    <field name="currency_id" invisible="1"/>
                                                    <field name="subtotal"/>
                                                </tree>
                                            </field>
                                        </page>
                                    </notebook>
                                </sheet>
                            </form>
                            <tree>
                                <field name="equipment_id"/>
                                <field name="equipment_category_id"/>
                                <field name="do_qi" widget="boolean_toggle"/>
                                <field name="qi_part01_declined" widget="boolean_toggle" optional="hide"/>
                                <field name="do_qo" widget="boolean_toggle" optional="hide"/>
                                <field name="do_qo_part01" widget="boolean_toggle" optional="hide"/>
                                <field name="qo_part01_declined" widget="boolean_toggle" optional="hide"/>
                                <field name="do_qs" widget="boolean_toggle"/>
                                <field name="currency_id" invisible="1"/>
                                <field name="subtotal"/>
                                <field name="estimated_days_total" optional="show"/>
                            </tree>
                        </field>
                    </div>

                    <!-- ETAPA 2 — OPCIONAIS -->
                    <div attrs="{'invisible': [('step', '!=', 'opcionais')]}">
                        <separator string="Serviços Opcionais"/>
                        <field name="optional_service_ids">
                            <tree editable="bottom">
                                <field name="optional_id"/>
                                <field name="qty"/>
                                <field name="unit_price"/>
                                <field name="accepted" widget="boolean_toggle"/>
                            </tree>
                        </field>
                        <separator string="Qualificações Opcionais"/>
                        <field name="optional_qualif_ids">
                            <tree editable="bottom">
                                <field name="equipment_id"
                                       domain="[('client_id','=',parent.partner_id)]"
                                       options="{'no_create': True}"/>
                                <field name="qualification_type"/>
                                <field name="cycle_type_id"/>
                                <field name="malha_type_id"/>
                                <field name="qty"/>
                                <field name="estimated_hours"/>
                                <field name="accepted" widget="boolean_toggle"/>
                            </tree>
                        </field>
                    </div>

                    <!-- ETAPA 3 — REVISÃO -->
                    <div attrs="{'invisible': [('step', '!=', 'revisao')]}">
                        <p>
                            Revise o escopo antes de aplicar ao pedido.
                        </p>
                        <field name="review_summary_html" nolabel="1" readonly="1"/>
                        <separator string="Opcionais Selecionados"
                                   attrs="{'invisible': [('optional_summary_html', 'in', (False, ''))]}"/>
                        <field name="optional_summary_html" nolabel="1" readonly="1"
                               attrs="{'invisible': [('optional_summary_html', 'in', (False, ''))]}"/>
                        <group>
                            <group/>
                            <group string="Totais">
                                <field name="currency_id" invisible="1"/>
                                <field name="equipment_count"/>
                                <field name="estimated_hours_total"/>
                                <field name="estimated_days_total"/>
                                <field name="total_estimated"/>
                            </group>
                        </group>
                        <p>
                            "Aplicar ao Pedido" recria as linhas de
                            qualificação. Os blocos de texto da proposta são
                            editados no próprio pedido (aba Proposta); serviços
                            opcionais (pasta, viagem, diária) são adicionados
                            como linhas avulsas no pedido.
                        </p>
                    </div>
                </sheet>
                <footer>
                    <button name="action_prev_step"
                            string="◀ Voltar"
                            type="object"
                            class="btn-secondary"
                            attrs="{'invisible': [('step', '=', 'escopo')]}"/>
                    <button name="action_next_step"
                            string="Próximo ▶"
                            type="object"
                            class="btn-primary"
                            attrs="{'invisible': [('step', '=', 'revisao')]}"/>
                    <button name="action_apply"
                            string="Aplicar ao Pedido"
                            type="object"
                            class="btn-primary"
                            attrs="{'invisible': [('step', '!=', 'revisao')]}"/>
                    <button string="Cancelar"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Bulk wizard -->
    <record id="view_qualificacao_configurator_bulk_form" model="ir.ui.view">
        <field name="name">afr.qualificacao.configurator.bulk.form</field>
        <field name="model">afr.qualificacao.configurator.bulk</field>
        <field name="arch" type="xml">
            <form string="Adicionar Vários Equipamentos">
                <sheet>
                    <group>
                        <field name="parent_wizard_id" invisible="1"/>
                        <field name="partner_id" readonly="1"/>
                        <field name="equipment_ids"
                               widget="many2many_tags"
                               domain="[('client_id','=',partner_id)]"/>
                    </group>
                    <group string="Qualificações Padrão (aplicadas a todos selecionados)">
                        <field name="do_qi"/>
                        <field name="do_qo" invisible="1"/>
                        <field name="do_qs"/>
                    </group>
                    <notebook>
                        <page string="Ciclos QO (sem carga)">
                            <field name="qo_line_ids">
                                <tree editable="bottom">
                                    <field name="cycle_type_id"/>
                                    <field name="description"/>
                                    <field name="temperature"/>
                                    <field name="duration"/>
                                    <field name="load_type"/>
                                    <field name="qty"/>
                                    <field name="unit_price"/>
                                    <field name="estimated_hours"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Ciclos QD (com carga)">
                            <field name="qd_line_ids">
                                <tree editable="bottom">
                                    <field name="cycle_type_id"/>
                                    <field name="description"/>
                                    <field name="temperature"/>
                                    <field name="duration"/>
                                    <field name="load_type"/>
                                    <field name="qty"/>
                                    <field name="unit_price"/>
                                    <field name="estimated_hours"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Malhas Calibração">
                            <field name="calib_line_ids">
                                <tree editable="bottom">
                                    <field name="malha_type_id"/>
                                    <field name="description"/>
                                    <field name="qty"/>
                                    <field name="unit_price"/>
                                    <field name="estimated_hours"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <footer>
                    <button name="action_apply"
                            string="Aplicar"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancelar"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
