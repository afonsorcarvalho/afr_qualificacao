<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="qq_block_optionals">
                            <t t-set="opt_lines" t-value="doc.order_line.filtered('is_proposal_optional')"/>
                            <div t-att-class="sec_class" t-if="opt_lines">
                                <div t-attf-class="qq-section-title{{ ' qq-section-title-child' if is_child else '' }}"
                                     t-if="block.show_title">
                                    <t t-if="blk_num"><span t-esc="blk_num"/> — </t>
                                    <span t-esc="block.title or 'Serviços Opcionais'"/>
                                </div>
                                <table class="qq-table">
                                    <tr>
                                        <th>Serviço</th>
                                        <th style="width: 10%;">Qtd</th>
                                        <th style="width: 20%; text-align: right;">Valor Unit.</th>
                                        <th style="width: 20%; text-align: right;">Subtotal</th>
                                    </tr>
                                    <t t-foreach="opt_lines" t-as="ol">
                                        <tr>
                                            <td><span t-esc="ol.name"/></td>
                                            <td>
                                                <span t-esc="int(ol.product_uom_qty) if ol.product_uom_qty == int(ol.product_uom_qty) else ol.product_uom_qty"/>
                                            </td>
                                            <td style="text-align: right;">
                                                <span t-esc="ol.price_unit"
                                                      t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                                            </td>
                                            <td style="text-align: right;">
                                                <span t-esc="ol.price_subtotal"
                                                      t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                                            </td>
                                        </tr>
                                    </t>
                                </table>
                            </div>
    </template>
</odoo>
