<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="qq_block_financial">
                            <div t-att-class="sec_class">
                                <div t-attf-class="qq-section-title{{ ' qq-section-title-child' if is_child else '' }}"
                                     t-if="block.show_title">
                                    <t t-if="blk_num"><span t-esc="blk_num"/> — </t>
                                    <span t-esc="block.title or 'Resumo Financeiro'"/>
                                </div>
                                <table class="qq-table">
                                    <tr>
                                        <th>Equipamento</th>
                                        <th style="text-align: right;">Subtotal</th>
                                    </tr>
                                    <t t-foreach="summary" t-as="eq">
                                        <tr>
                                            <td><span t-esc="eq['equipment'].name"/></td>
                                            <td style="text-align: right;">
                                                <span t-esc="eq['subtotal']"
                                                      t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                                            </td>
                                        </tr>
                                    </t>
                                </table>
                                <table class="qq-total-table">
                                    <t t-set="equip_total" t-value="sum(eq['subtotal'] for eq in summary)"/>
                                    <t t-set="optional_total" t-value="sum(l.price_subtotal for l in doc.order_line if l.is_proposal_optional and l.optional_accepted)"/>
                                    <tr>
                                        <td class="qq-tot-label">Subtotal:</td>
                                        <td class="qq-tot-value">
                                            <span t-esc="equip_total"
                                                  t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                                        </td>
                                    </tr>
                                    <t t-if="optional_total">
                                        <tr>
                                            <td class="qq-tot-label">Opcionais:</td>
                                            <td class="qq-tot-value">
                                                <span t-esc="optional_total"
                                                      t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                                            </td>
                                        </tr>
                                    </t>
                                    <tr class="qq-total-grand">
                                        <td class="qq-tot-label">TOTAL GERAL:</td>
                                        <td class="qq-tot-value">
                                            <span t-esc="equip_total + optional_total"
                                                  t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                                        </td>
                                    </tr>
                                </table>
                            </div>
    </template>
</odoo>
