<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Inherit do template padrão Odoo `sale.report_saleorder_document`.

        Estratégia (preserva fallback Odoo):
        1. Adiciona `t-if="not (doc.has_qualif_lines or doc.proposal_block_ids.filtered('included'))"`
           no <div class="page"> original — esconde quando SO tem linhas de
           qualificação OU blocos de proposta incluídos.
        2. Insere novo <div class="page" t-if="doc.has_qualif_lines or doc.proposal_block_ids.filtered('included')">
           antes, com layout dedicado (capa + sumário + descritivo + escopo +
           normas + resumo financeiro + condições + aceite).

        Mantém `web.external_layout` (logo + footer) em ambos os fluxos.

        Cores neutras (#333/#666/#999/#ddd). PT-BR. A4 retrato.
    -->
    <template id="report_saleorder_document_qualif"
              inherit_id="sale.report_saleorder_document"
              name="Cotação Qualificação (AFR)">

        <!-- Condiciona o div page original — fallback Odoo padrão -->
        <xpath expr="//div[hasclass('page')]" position="attributes">
            <attribute name="t-if">not (doc.has_qualif_lines or doc.proposal_block_ids.filtered('included'))</attribute>
        </xpath>

        <!-- Insere novo div page com layout dedicado -->
        <xpath expr="//div[hasclass('page')]" position="before">
            <div class="page qq-page" t-if="doc.has_qualif_lines or doc.proposal_block_ids.filtered('included')">
                <!-- F9.2: remove base href tag from web.minimal_layout.
                     wkhtmltopdf respects base tag; with it, "#anchor" hrefs
                     resolve to absolute URLs, breaking internal PDF links.
                     Refs: drupal.org/project/print/issues/1313754
                           github.com/wkhtmltopdf/wkhtmltopdf/issues/3486 -->
                <script type="text/javascript">
                    // F9.2: wait for window.load so ALL images/CSS already loaded
                    // by browser using current base. Then absolutize URLs and
                    // remove base so fragment hrefs (#anchor) become internal PDF links.
                    // Runs within wkhtmltopdf --javascript-delay (default 1000ms).
                    window.addEventListener('load', function() {
                        var bases = document.getElementsByTagName('base');
                        if (!bases.length) return;
                        // Snapshot resolved URLs (getter returns abs URL via current base)
                        var imgs = document.getElementsByTagName('img');
                        for (var i = 0; i &lt; imgs.length; i++) {
                            var srcAttr = imgs[i].getAttribute('src');
                            if (srcAttr &amp;&amp; srcAttr.charAt(0) !== '#') {
                                imgs[i].setAttribute('src', imgs[i].src);
                            }
                        }
                        var linksHead = document.getElementsByTagName('link');
                        for (var k = 0; k &lt; linksHead.length; k++) {
                            var hrefAttr = linksHead[k].getAttribute('href');
                            if (hrefAttr &amp;&amp; hrefAttr.charAt(0) !== '#') {
                                linksHead[k].setAttribute('href', linksHead[k].href);
                            }
                        }
                        // Rewrite ONLY external/relative anchor links (not fragment-only #X)
                        var anchors = document.getElementsByTagName('a');
                        for (var a = 0; a &lt; anchors.length; a++) {
                            var hrefA = anchors[a].getAttribute('href');
                            if (hrefA &amp;&amp; hrefA.charAt(0) !== '#') {
                                anchors[a].setAttribute('href', anchors[a].href);
                            }
                        }
                        // Finally remove base — fragment hrefs stay #X (internal)
                        for (var j = bases.length - 1; j >= 0; j--) {
                            bases[j].parentNode.removeChild(bases[j]);
                        }
                    });
                </script>
                <t t-call="afr_qualificacao.qq_styles"/>

                <!-- ========================================================
                     SECÇÃO 1 — CAPA
                ========================================================= -->
                <div class="qq-cover">
                    <div class="qq-cover-title">
                        PROPOSTA TÉCNICO-COMERCIAL
                    </div>
                    <div class="qq-cover-subtitle">
                        Qualificação de Equipamentos
                    </div>

                    <div class="qq-cover-meta">
                        <div>
                            <strong>Nº:</strong>
                            <span t-field="doc.name"/>
                        </div>
                        <div>
                            <strong>Cliente:</strong>
                            <span t-field="doc.partner_id.name"/>
                        </div>
                        <div t-if="doc.partner_id.vat">
                            <strong>CNPJ/CPF:</strong>
                            <span t-field="doc.partner_id.vat"/>
                        </div>
                        <div>
                            <strong>Data:</strong>
                            <span t-field="doc.date_order" t-options="{'widget': 'date'}"/>
                        </div>
                        <div t-if="doc.validity_date">
                            <strong>Validade:</strong>
                            <span t-field="doc.validity_date"/>
                        </div>
                    </div>

                    <div class="qq-cover-footer">
                        Emitido por
                        <span t-field="doc.company_id.name"/>
                    </div>

                    <!-- Imagem de capa (collage de equipamentos) -->
                    <img class="qq-cover-img"
                         src="/afr_qualificacao/static/img/cover_default.jpg"
                         alt="LabQuali — Qualificação de Equipamentos"/>
                </div>

                <!-- ========================================================
                     SECÇÃO 2 — SUMÁRIO EXECUTIVO
                ========================================================= -->
                <t t-set="summary" t-value="doc._qualif_equipment_summary()"/>
                <t t-set="type_descs" t-value="doc._qualif_type_descriptions()"/>

                <!-- F9.1 — numeração hierárquica {block_id: 'N' | 'N.M' | ''} -->
                <t t-set="block_numbers" t-value="doc._proposal_block_numbering() if doc.proposal_block_ids.filtered('included') else {}"/>

                <!-- ========================================================
                     F9.2 — ÍNDICE (TOC) — após capa, antes dos blocos
                     Links internos ancorados em qq-anchor-#{block.id}.
                     Apenas blocos com show_title=True aparecem no índice.
                ========================================================= -->
                <t t-if="doc.proposal_block_ids.filtered(lambda b: b.included and b.show_title)">
                    <div class="qq-section qq-toc">
                        <div class="qq-section-title">Índice</div>
                        <ul class="qq-toc-list">
                            <t t-foreach="doc.proposal_block_ids.filtered(lambda b: b.included and b.show_title)" t-as="tb">
                                <t t-set="tb_num" t-value="block_numbers.get(tb.id, '')"/>
                                <li t-attf-class="qq-toc-item#{' qq-toc-child' if tb.parent_id else ''}">
                                    <a t-attf-href="#qq-anchor-#{tb.id}" class="qq-toc-link">
                                        <span class="qq-toc-num" t-if="tb_num"><t t-esc="tb_num"/></span>
                                        <span class="qq-toc-title" t-esc="tb.title or tb.display_name"/>
                                    </a>
                                </li>
                            </t>
                        </ul>
                    </div>
                </t>

                <!-- ========================================================
                     F8.3 — Proposta LEGO: percorre os blocos montados na
                     cotação (proposal_block_ids, incluídos, ordenados).
                     Fallback para o layout fixo quando a SO não tem blocos.
                ========================================================= -->
                <t t-if="doc.proposal_block_ids.filtered('included')">
                    <t t-foreach="doc.proposal_block_ids.filtered('included')" t-as="block">

                        <!-- F8.6 — quebra de página por bloco (page_break).
                             Sem quebra → classe qq-section-cont (continua). -->
                        <t t-set="sec_class"
                           t-value="'qq-section' if block.page_break else 'qq-section qq-section-cont'"/>
                        <!-- F9.1 — número hierárquico e flag de filho para indent -->
                        <t t-set="blk_num" t-value="block_numbers.get(block.id, '')"/>
                        <t t-set="is_child" t-value="bool(block.parent_id)"/>
                        <!-- F9.2 — anchor interno para links do TOC.
                             IMPORTANTE: WebKit (wkhtmltopdf) REMOVE âncoras vazias.
                             Conteúdo &#160; (nbsp) impede remoção. Ref:
                             https://github.com/wkhtmltopdf/wkhtmltopdf/issues/3486 -->
                        <a t-attf-name="qq-anchor-#{block.id}"
                           t-attf-id="qq-anchor-#{block.id}"
                           style="text-decoration:none;color:inherit;">&#160;</a>

                        <!-- Bloco de texto estático -->
                        <t t-if="block.block_kind == 'static'">
                            <t t-call="afr_qualificacao.qq_block_static"/>
                        </t>

                        <!-- Escopo por equipamento -->
                        <t t-if="block.block_kind == 'equipment_scope'">
                            <t t-call="afr_qualificacao.qq_block_equipment_scope"/>
                        </t>

                        <!-- Tabela de ciclos (specs técnicas) -->
                        <t t-if="block.block_kind == 'cycle_specs'">
                            <t t-call="afr_qualificacao.qq_block_cycle_specs"/>
                        </t>

                        <!-- F8.14 — Bloco Cronograma (template-opcional) -->
                        <t t-if="block.block_kind == 'schedule'">
                            <t t-call="afr_qualificacao.qq_block_schedule"/>
                        </t>

                        <!-- Tabela de normas -->
                        <t t-if="block.block_kind == 'standards_table'">
                            <t t-call="afr_qualificacao.qq_block_standards_table"/>
                        </t>

                        <!-- Resumo financeiro -->
                        <t t-if="block.block_kind == 'financial'">
                            <t t-call="afr_qualificacao.qq_block_financial"/>
                        </t>

                        <!-- Serviços opcionais -->
                        <t t-if="block.block_kind == 'optionals'">
                            <t t-call="afr_qualificacao.qq_block_optionals"/>
                        </t>

                        <!-- Tabela de itens de venda (Venda + Calibração) -->
                        <t t-if="block.block_kind == 'sales_items'">
                            <t t-call="afr_qualificacao.qq_block_sales_items"/>
                        </t>

                        <!-- Aceite -->
                        <t t-if="block.block_kind == 'acceptance'">
                            <t t-call="afr_qualificacao.qq_block_acceptance"/>
                        </t>

                    </t>
                </t>
                <t t-else="">

                <div class="qq-section">
                    <div class="qq-section-title">Sumário Executivo</div>
                    <p>
                        Esta proposta descreve o escopo técnico-comercial dos
                        serviços de qualificação a serem prestados para
                        <strong t-field="doc.partner_id.name"/>.
                    </p>
                    <table class="qq-table">
                        <tr>
                            <th style="width: 40%;">Item</th>
                            <th>Conteúdo</th>
                        </tr>
                        <tr>
                            <td><strong>Equipamentos abrangidos</strong></td>
                            <td><span t-esc="len(summary)"/></td>
                        </tr>
                        <tr>
                            <td><strong>Tipos de serviço incluídos</strong></td>
                            <td>
                                <t t-foreach="type_descs" t-as="td">
                                    <span t-esc="td['label']"/><t t-if="not td_last">; </t>
                                </t>
                            </td>
                        </tr>
                        <tr t-if="doc.qualif_standard_ids">
                            <td><strong>Normas aplicáveis</strong></td>
                            <td>
                                <t t-foreach="doc.qualif_standard_ids" t-as="std">
                                    <span t-esc="std.code"/><t t-if="not std_last">; </t>
                                </t>
                            </td>
                        </tr>
                        <tr t-if="doc.user_id">
                            <td><strong>Responsável comercial</strong></td>
                            <td>
                                <span t-field="doc.user_id.name"/>
                                <t t-if="doc.user_id.email">
                                    · <span t-field="doc.user_id.email"/>
                                </t>
                            </td>
                        </tr>
                    </table>
                </div>

                <!-- ========================================================
                     SECÇÃO 3 — DESCRITIVO TÉCNICO
                     (continua na mesma página do Sumário Executivo)
                ========================================================= -->
                <div class="qq-section qq-section-cont">
                    <div class="qq-section-title">Descritivo Técnico</div>
                    <p>
                        A seguir, descrição dos tipos de qualificação
                        contemplados nesta proposta.
                    </p>
                    <t t-foreach="type_descs" t-as="td">
                        <div class="qq-descritivo-block">
                            <div class="qq-descritivo-label">
                                <span t-esc="td['label']"/>
                            </div>
                            <div class="qq-descritivo-text">
                                <span t-esc="td['description']"/>
                            </div>
                        </div>
                    </t>
                </div>

                <!-- ========================================================
                     SECÇÃO 4 — ESCOPO POR EQUIPAMENTO
                ========================================================= -->
                <div class="qq-section">
                    <div class="qq-section-title">Escopo por Equipamento</div>
                    <p>
                        Detalhamento dos serviços a serem executados em cada
                        equipamento. Subtotais não incluem impostos.
                    </p>
                    <t t-foreach="summary" t-as="eq">
                        <div class="qq-equip-card">
                            <div class="qq-equip-header">
                                <span t-esc="eq['equipment'].name"/>
                                <span class="qq-equip-meta">
                                    <t t-if="eq['equipment'].serial_number">
                                        · S/N:
                                        <span t-esc="eq['equipment'].serial_number"/>
                                    </t>
                                    <t t-if="eq['equipment'].category_id">
                                        · Categoria:
                                        <span t-esc="eq['equipment'].category_id.name"/>
                                    </t>
                                </span>
                            </div>
                            <t t-foreach="eq['types']" t-as="tp">
                                <div class="qq-type-block">
                                    <div class="qq-type-label">
                                        <span t-esc="tp['label']"/>
                                    </div>
                                    <ul class="qq-item-list">
                                        <t t-foreach="tp['items']" t-as="it">
                                            <li>
                                                <span t-esc="it['name']"/>
                                                <t t-if="it['qty'] and it['qty'] != 1">
                                                    — quantidade:
                                                    <span t-esc="int(it['qty']) if it['qty'] == int(it['qty']) else it['qty']"/>
                                                </t>
                                            </li>
                                        </t>
                                    </ul>
                                </div>
                            </t>
                            <div class="qq-equip-subtotal">
                                Subtotal do equipamento:
                                <span t-esc="eq['subtotal']"
                                      t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                            </div>
                        </div>
                    </t>
                </div>

                <!-- ========================================================
                     SECÇÃO 5 — NORMAS APLICÁVEIS
                ========================================================= -->
                <div class="qq-section" t-if="doc.qualif_standard_ids">
                    <div class="qq-section-title">Normas Aplicáveis</div>
                    <p>
                        Os serviços contemplados nesta proposta atendem às
                        seguintes normas técnicas e regulatórias.
                    </p>
                    <table class="qq-table">
                        <tr>
                            <th style="width: 22%;">Código</th>
                            <th style="width: 38%;">Nome</th>
                            <th style="width: 15%;">Organismo</th>
                            <th>Escopo</th>
                        </tr>
                        <t t-foreach="doc.qualif_standard_ids" t-as="std">
                            <tr>
                                <td>
                                    <strong t-esc="std.code"/>
                                </td>
                                <td>
                                    <span t-esc="std.name"/>
                                </td>
                                <td>
                                    <span class="qq-norma-organism" t-esc="std.organism or ''"/>
                                </td>
                                <td>
                                    <span t-esc="std.description or ''"/>
                                </td>
                            </tr>
                        </t>
                    </table>
                </div>

                <!-- ========================================================
                     SECÇÃO 6 — RESUMO FINANCEIRO
                ========================================================= -->
                <div class="qq-section">
                    <div class="qq-section-title">Resumo Financeiro</div>
                    <p>
                        Resumo dos valores conforme escopo apresentado. Valores
                        em
                        <span t-esc="doc.currency_id.name"/>.
                    </p>
                    <table class="qq-table">
                        <tr>
                            <th>Equipamento</th>
                            <th class="text-end" style="text-align: right;">Subtotal</th>
                        </tr>
                        <t t-foreach="summary" t-as="eq">
                            <tr>
                                <td>
                                    <span t-esc="eq['equipment'].name"/>
                                </td>
                                <td style="text-align: right;">
                                    <span t-esc="eq['subtotal']"
                                          t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                                </td>
                            </tr>
                        </t>
                    </table>

                    <table class="qq-total-table">
                        <tr>
                            <td class="qq-tot-label">Subtotal:</td>
                            <td class="qq-tot-value">
                                <span t-field="doc.amount_untaxed"
                                      t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                            </td>
                        </tr>
                        <tr>
                            <td class="qq-tot-label">Impostos:</td>
                            <td class="qq-tot-value">
                                <span t-field="doc.amount_tax"
                                      t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                            </td>
                        </tr>
                        <tr class="qq-total-grand">
                            <td class="qq-tot-label">TOTAL GERAL:</td>
                            <td class="qq-tot-value">
                                <span t-field="doc.amount_total"
                                      t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                            </td>
                        </tr>
                    </table>
                </div>

                <!-- ========================================================
                     SECÇÃO 7 — CONDIÇÕES COMERCIAIS
                     (continua na mesma página do Resumo Financeiro)
                ========================================================= -->
                <div class="qq-section qq-section-cont">
                    <div class="qq-section-title">Condições Comerciais</div>

                    <div class="qq-conditions-grid">
                        <div class="qq-conditions-cell">
                            <strong>Validade da Proposta</strong>
                            <t t-if="doc.validity_date">
                                <span t-field="doc.validity_date"/>
                            </t>
                            <t t-else="">
                                <em>Consultar responsável comercial.</em>
                            </t>
                        </div>
                        <div class="qq-conditions-cell">
                            <strong>Condição de Pagamento</strong>
                            <t t-if="doc.payment_term_id">
                                <span t-field="doc.payment_term_id.name"/>
                            </t>
                            <t t-else="">
                                <em>A combinar.</em>
                            </t>
                        </div>
                        <div class="qq-conditions-cell">
                            <strong>Responsável Comercial</strong>
                            <t t-if="doc.user_id">
                                <div t-field="doc.user_id.name"/>
                                <div t-if="doc.user_id.email"
                                     class="text-muted" style="font-size: 13px;">
                                    <span t-field="doc.user_id.email"/>
                                </div>
                                <div t-if="doc.user_id.phone"
                                     class="text-muted" style="font-size: 13px;">
                                    <span t-field="doc.user_id.phone"/>
                                </div>
                            </t>
                        </div>
                    </div>

                    <div t-if="doc.note" class="qq-descritivo-block">
                        <div class="qq-subsection-title">Termos e Observações</div>
                        <div class="qq-descritivo-text">
                            <span t-field="doc.note"/>
                        </div>
                    </div>

                    <div t-if="doc.payment_term_id and not is_html_empty(doc.payment_term_id.note)"
                         class="qq-descritivo-block">
                        <div class="qq-subsection-title">Observações de Pagamento</div>
                        <div class="qq-descritivo-text">
                            <span t-field="doc.payment_term_id.note"/>
                        </div>
                    </div>
                </div>

                <!-- ========================================================
                     SECÇÃO 8 — ACEITE
                     (continua na mesma página de Financeiro + Condições)
                ========================================================= -->
                <div class="qq-section qq-section-cont qq-signature-block">
                    <div class="qq-section-title">Aceite da Proposta</div>
                    <p>
                        Declaro estar de acordo com os termos, escopo e
                        valores apresentados nesta Proposta Técnico-Comercial
                        <strong t-field="doc.name"/>.
                    </p>

                    <div class="qq-signature-row">
                        <div class="qq-signature-col">
                            <div class="qq-signature-line"/>
                            <div class="qq-signature-label">
                                <strong>CLIENTE</strong>
                                <br/>
                                <span t-field="doc.partner_id.name"/>
                                <br/>
                                Nome, cargo, assinatura e carimbo
                            </div>
                        </div>
                        <div class="qq-signature-col">
                            <div class="qq-signature-line"/>
                            <div class="qq-signature-label">
                                <strong>EMPRESA</strong>
                                <br/>
                                <span t-field="doc.company_id.name"/>
                                <br/>
                                Nome, cargo, assinatura
                            </div>
                        </div>
                    </div>

                    <div style="margin-top: 30px; text-align: center; font-size: 14px;">
                        <strong>Local e data:</strong>
                        ____________________________________, ____ / ____ / ________
                    </div>
                </div>
                </t>
            </div>
        </xpath>
    </template>
</odoo>
