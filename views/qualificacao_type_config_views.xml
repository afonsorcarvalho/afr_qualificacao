<?xml version="1.0" encoding="utf-8"?>
<!--
    Configuração comercial por tipo de qualificação.
    Referência: https://www.odoo.com/documentation/16.0/developer/reference/backend/views.html
-->
<odoo>
    <record id="view_afr_qualificacao_type_config_tree" model="ir.ui.view">
        <field name="name">afr.qualificacao.type.config.tree</field>
        <field name="model">afr.qualificacao.type.config</field>
        <field name="arch" type="xml">
            <tree string="Configurações de Tipo de Qualificação">
                <field name="qualification_type"/>
                <field name="service_product_id"/>
                <field name="default_unit_price" widget="monetary"/>
                <field name="estimated_hours"/>
                <field name="currency_id" invisible="1"/>
                <field name="analytic_account_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_afr_qualificacao_type_config_form" model="ir.ui.view">
        <field name="name">afr.qualificacao.type.config.form</field>
        <field name="model">afr.qualificacao.type.config</field>
        <field name="arch" type="xml">
            <form string="Configuração de Tipo de Qualificação">
                <sheet>
                    <widget name="web_ribbon" title="Arquivado" bg_color="bg-danger" attrs="{'invisible': [('active', '=', True)]}"/>
                    <group>
                        <group>
                            <field name="qualification_type"/>
                            <field name="service_product_id" options="{'no_create_edit': True}"/>
                            <field name="default_unit_price" widget="monetary"/>
                            <field name="estimated_hours"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="analytic_account_id" options="{'no_create_edit': True}"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_afr_qualificacao_type_config" model="ir.actions.act_window">
        <field name="name">Tipos de Qualificação</field>
        <field name="res_model">afr.qualificacao.type.config</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Configure um produto de serviço por tipo de qualificação.
            </p>
            <p>
                O produto será usado como padrão ao criar pedidos de venda
                vinculados às qualificações deste tipo.
            </p>
        </field>
    </record>
</odoo>
