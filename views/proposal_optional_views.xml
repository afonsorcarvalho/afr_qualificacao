<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_proposal_optional_tree" model="ir.ui.view">
        <field name="name">afr.proposal.optional.tree</field>
        <field name="model">afr.proposal.optional</field>
        <field name="arch" type="xml">
            <tree string="Serviços Opcionais">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="kind"/>
                <field name="product_id"/>
                <field name="default_price"/>
                <field name="default_qty"/>
                <field name="currency_id" invisible="1"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <record id="view_proposal_optional_form" model="ir.ui.view">
        <field name="name">afr.proposal.optional.form</field>
        <field name="model">afr.proposal.optional</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="kind"/>
                            <field name="product_id"/>
                        </group>
                        <group>
                            <field name="default_price"/>
                            <field name="default_qty"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="sequence"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_proposal_optional" model="ir.actions.act_window">
        <field name="name">Serviços Opcionais</field>
        <field name="res_model">afr.proposal.optional</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
