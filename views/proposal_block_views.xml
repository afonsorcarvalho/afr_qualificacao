<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- F9.2 — tree standalone para popup "Pesquisar mais" do parent_id -->
    <record id="view_proposal_block_tree" model="ir.ui.view">
        <field name="name">afr.proposal.block.tree</field>
        <field name="model">afr.proposal.block</field>
        <field name="arch" type="xml">
            <tree string="Blocos da Proposta" create="false" edit="false">
                <field name="sale_order_id"/>
                <field name="display_number" string="Nº"/>
                <field name="block_kind"/>
                <field name="display_label" string="Conteúdo"/>
            </tree>
        </field>
    </record>

    <!-- F8.5 — editor de bloco da proposta em modal (botão "Editar"). -->
    <record id="view_proposal_block_form" model="ir.ui.view">
        <field name="name">afr.proposal.block.form</field>
        <field name="model">afr.proposal.block</field>
        <field name="arch" type="xml">
            <form string="Bloco da Proposta">
                <sheet>
                    <group>
                        <group>
                            <field name="block_kind" readonly="1"/>
                            <field name="title"/>
                        </group>
                        <group>
                            <field name="included"/>
                            <field name="page_break"/>
                            <field name="section_id" readonly="1"/>
                        </group>
                    </group>
                    <separator string="Conteúdo (aceita {{ expressões }})"/>
                    <field name="body" options="{'codeview': True}"/>
                </sheet>
                <footer>
                    <button string="Salvar e Fechar"
                            class="btn-primary"
                            special="save"/>
                    <button string="Descartar"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
