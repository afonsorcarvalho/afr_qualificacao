<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ======================================================== -->
    <!-- FORM: procedimento (template)                             -->
    <!-- ======================================================== -->
    <record id="view_afr_qualificacao_procedimento_form" model="ir.ui.view">
        <field name="name">afr.qualificacao.procedimento.form</field>
        <field name="model">afr.qualificacao.procedimento</field>
        <field name="arch" type="xml">
            <form string="Procedimento de Qualificação">
                <sheet>
                    <widget name="web_ribbon" title="Arquivado" bg_color="bg-danger"
                            attrs="{'invisible': [('active', '=', True)]}"/>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" placeholder="Ex.: QD Autoclave Vapor — Procedimento Padrão"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Aplicabilidade">
                            <field name="equipment_category_id"
                                   options="{'no_create': True}"/>
                            <field name="code"/>
                            <field name="sequence"/>
                        </group>
                        <group string="Status">
                            <field name="active"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="item_count"/>
                        </group>
                    </group>
                    <separator string="Descrição"/>
                    <field name="description" placeholder="Breve descrição do procedimento (aparece para o técnico em campo)."/>
                    <notebook>
                        <page string="QI · Instalação">
                            <field name="item_ids" mode="tree"
                                   domain="[('phase', '=', 'installation')]"
                                   context="{'default_phase': 'installation'}">
                                <tree editable="bottom">
                                    <field name="phase" column_invisible="1"/>
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="kind"/>
                                    <field name="target_level"/>
                                    <field name="required"/>
                                    <field name="requires_instrument"
                                           widget="boolean_toggle" optional="show"/>
                                    <field name="required_sensor_kind_ids"
                                           widget="many2many_tags" optional="show"
                                           options="{'no_create_edit': True}"/>
                                    <field name="docx_section" optional="show"/>
                                    <field name="mimetypes_hint" optional="hide"/>
                                    <field name="instruction" optional="hide"/>
                                </tree>
                            </field>
                        </page>
                        <page string="QO · Operacional">
                            <field name="item_ids" mode="tree"
                                   domain="[('phase', '=', 'operational')]"
                                   context="{'default_phase': 'operational'}">
                                <tree editable="bottom">
                                    <field name="phase" column_invisible="1"/>
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="kind"/>
                                    <field name="target_level"/>
                                    <field name="required"/>
                                    <field name="requires_instrument"
                                           widget="boolean_toggle" optional="show"/>
                                    <field name="required_sensor_kind_ids"
                                           widget="many2many_tags" optional="show"
                                           options="{'no_create_edit': True}"/>
                                    <field name="docx_section" optional="show"/>
                                    <field name="mimetypes_hint" optional="hide"/>
                                    <field name="instruction" optional="hide"/>
                                </tree>
                            </field>
                        </page>
                        <page string="QD · Desempenho">
                            <field name="item_ids" mode="tree"
                                   domain="[('phase', '=', 'performance')]"
                                   context="{'default_phase': 'performance'}">
                                <tree editable="bottom">
                                    <field name="phase" column_invisible="1"/>
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="kind"/>
                                    <field name="target_level"/>
                                    <field name="required"/>
                                    <field name="requires_instrument"
                                           widget="boolean_toggle" optional="show"/>
                                    <field name="required_sensor_kind_ids"
                                           widget="many2many_tags" optional="show"
                                           options="{'no_create_edit': True}"/>
                                    <field name="docx_section" optional="show"/>
                                    <field name="mimetypes_hint" optional="hide"/>
                                    <field name="instruction" optional="hide"/>
                                </tree>
                            </field>
                        </page>
                        <page string="QS · Software">
                            <field name="item_ids" mode="tree"
                                   domain="[('phase', '=', 'software')]"
                                   context="{'default_phase': 'software'}">
                                <tree editable="bottom">
                                    <field name="phase" column_invisible="1"/>
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="kind"/>
                                    <field name="target_level"/>
                                    <field name="required"/>
                                    <field name="requires_instrument"
                                           widget="boolean_toggle" optional="show"/>
                                    <field name="required_sensor_kind_ids"
                                           widget="many2many_tags" optional="show"
                                           options="{'no_create_edit': True}"/>
                                    <field name="docx_section" optional="show"/>
                                    <field name="mimetypes_hint" optional="hide"/>
                                    <field name="instruction" optional="hide"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Calibração">
                            <field name="item_ids" mode="tree"
                                   domain="[('phase', '=', 'calibration')]"
                                   context="{'default_phase': 'calibration'}">
                                <tree editable="bottom">
                                    <field name="phase" column_invisible="1"/>
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="kind"/>
                                    <field name="target_level"/>
                                    <field name="required"/>
                                    <field name="requires_instrument"
                                           widget="boolean_toggle" optional="show"/>
                                    <field name="required_sensor_kind_ids"
                                           widget="many2many_tags" optional="show"
                                           options="{'no_create_edit': True}"/>
                                    <field name="docx_section" optional="show"/>
                                    <field name="mimetypes_hint" optional="hide"/>
                                    <field name="instruction" optional="hide"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ======================================================== -->
    <!-- TREE                                                      -->
    <!-- ======================================================== -->
    <record id="view_afr_qualificacao_procedimento_tree" model="ir.ui.view">
        <field name="name">afr.qualificacao.procedimento.tree</field>
        <field name="model">afr.qualificacao.procedimento</field>
        <field name="arch" type="xml">
            <tree>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="equipment_category_id" optional="show"/>
                <field name="item_count" string="Itens"/>
                <field name="code" optional="hide"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <!-- ======================================================== -->
    <!-- SEARCH                                                    -->
    <!-- ======================================================== -->
    <record id="view_afr_qualificacao_procedimento_search" model="ir.ui.view">
        <field name="name">afr.qualificacao.procedimento.search</field>
        <field name="model">afr.qualificacao.procedimento</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="equipment_category_id"/>
                <filter string="Arquivados" name="filter_inactive"
                        domain="[('active', '=', False)]"/>
                <group expand="0" string="Agrupar por">
                    <filter string="Categoria" name="group_category"
                            context="{'group_by': 'equipment_category_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_afr_qualificacao_procedimento" model="ir.actions.act_window">
        <field name="name">Procedimentos de Qualificação</field>
        <field name="res_model">afr.qualificacao.procedimento</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_afr_qualificacao_procedimento_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crie um procedimento de qualificação (template)
            </p>
            <p>
                Procedimentos definem os itens a coletar em campo (fotos, planilhas,
                dados do qualificador) por tipo de qualificação + categoria de equipamento.
                Carregado automaticamente ao criar a OS via SO confirm.
            </p>
        </field>
    </record>

</odoo>
