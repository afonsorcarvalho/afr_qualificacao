<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================== -->
    <!-- Inherit tree padrão: adiciona coluna "Cert. Válido"             -->
    <!-- ============================================================== -->
    <record id="view_engc_calibration_instruments_tree_inherit_qualif" model="ir.ui.view">
        <field name="name">engc.calibration.instruments.tree.qualif</field>
        <field name="model">engc.calibration.instruments</field>
        <field name="inherit_id" ref="engc_os.calibration_instruments_list"/>
        <field name="arch" type="xml">
            <field name="modelo" position="after">
                <field name="tag" optional="hide"/>
                <field name="has_valid_certificate" widget="boolean_toggle" readonly="1"/>
            </field>
        </field>
    </record>

    <!-- ============================================================== -->
    <!-- Inherit form padrão: badge "É válido" na tree de certificados   -->
    <!-- e indicador no header                                           -->
    <!-- ============================================================== -->
    <record id="view_engc_calibration_instruments_form_inherit_qualif" model="ir.ui.view">
        <field name="name">engc.calibration.instruments.form.qualif</field>
        <field name="model">engc.calibration.instruments</field>
        <field name="inherit_id" ref="engc_os.calibration_instruments_form"/>
        <field name="arch" type="xml">
            <xpath expr="//h2[1]" position="before">
                <div class="oe_button_box" name="qualif_button_box">
                    <field name="has_valid_certificate" invisible="1"/>
                    <div class="badge text-bg-success float-end m-2"
                         attrs="{'invisible': [('has_valid_certificate', '=', False)]}">
                        <i class="fa fa-check" title="Válido" role="img" aria-label="Válido"/>
                        Certificado Válido
                    </div>
                    <div class="badge text-bg-danger float-end m-2"
                         attrs="{'invisible': [('has_valid_certificate', '=', True)]}">
                        <i class="fa fa-exclamation-triangle" title="Expirado" role="img" aria-label="Expirado"/>
                        Sem Certificado Válido
                    </div>
                </div>
            </xpath>
            <xpath expr="//field[@name='certificate_ids']/tree/field[@name='validate_calibration']" position="after">
                <field name="is_valid" widget="boolean_toggle" readonly="1" string="Válido"/>
            </xpath>
        </field>
    </record>

    <!-- ============================================================== -->
    <!-- Action + menuitem dedicados em Qualificações > Configurações    -->
    <!-- ============================================================== -->
    <record id="action_calibration_instruments_qualif" model="ir.actions.act_window">
        <field name="name">Padrões Metrológicos</field>
        <field name="res_model">engc.calibration.instruments</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Cadastre instrumentos padrão de medição
            </p>
            <p>
                Cada instrumento agrega um histórico de certificados de calibração
                com data de validade. Use-os nas coletas das qualificações para
                rastrear quais padrões foram utilizados na execução.
            </p>
        </field>
    </record>

    <!-- Menu restrito ao gestor: técnico não cria/edita/deleta padrões.
         Técnico apenas seleciona instrumentos existentes via M2M no collect.item. -->
    <menuitem
        id="menu_afr_qualificacao_calibration_instruments"
        name="Padrões Metrológicos (Instrumentos)"
        parent="menu_afr_qualificacao_config"
        action="action_calibration_instruments_qualif"
        sequence="65"
        groups="afr_qualificacao.group_afr_qualificacao_manager"
    />

</odoo>
