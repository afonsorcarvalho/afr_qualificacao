<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_proposal_section_tree" model="ir.ui.view">
        <field name="name">afr.proposal.section.tree</field>
        <field name="model">afr.proposal.section</field>
        <field name="arch" type="xml">
            <tree string="Blocos de Proposta">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="category"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <record id="view_proposal_section_form" model="ir.ui.view">
        <field name="name">afr.proposal.section.form</field>
        <field name="model">afr.proposal.section</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="category"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <separator string="Conteúdo (aceita {{ expressões }})"/>
                    <field name="body" options="{'codeview': True}"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_proposal_section" model="ir.actions.act_window">
        <field name="name">Blocos de Proposta</field>
        <field name="res_model">afr.proposal.section</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
