<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_view_form_afr_qualificacao" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.afr_qualificacao</field>
        <field name="model">res.config.settings</field>
        <field name="priority">90</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('settings')]" position="inside">
                <div class="app_settings_block"
                     data-string="AFR Qualificação"
                     string="AFR Qualificação"
                     data-key="afr_qualificacao"
                     groups="afr_qualificacao.group_afr_qualificacao_manager">
                    <h2>Aprovação de Qualificações</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="qualif_block_approval_expired_standards"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="qualif_block_approval_expired_standards"/>
                                <div class="text-muted">
                                    Bloqueia <code>action_mark_approved</code> se algum padrão metrológico
                                    referenciado em coletas estiver sem certificado de calibração válido
                                    (data de validade &gt;= hoje). Quando desligado, apenas registra aviso no chatter.
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="qualif_block_approval_incomplete_coverage"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="qualif_block_approval_incomplete_coverage"/>
                                <div class="text-muted">
                                    F4.3: bloqueia <code>action_mark_approved</code> se algum collect.item
                                    obrigatório (<code>required + requires_instrument</code>) tem cobertura
                                    de grandezas incompleta — alguma grandeza requerida não está coberta
                                    pelos instrumentos selecionados. Quando desligado, apenas registra aviso.
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>

</odoo>
