<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_proposal_template_tree" model="ir.ui.view">
        <field name="name">afr.proposal.template.tree</field>
        <field name="model">afr.proposal.template</field>
        <field name="arch" type="xml">
            <tree string="Templates de Proposta">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <record id="view_proposal_template_form" model="ir.ui.view">
        <field name="name">afr.proposal.template.form</field>
        <field name="model">afr.proposal.template</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <separator string="Blocos da Proposta (na ordem de impressão)"/>
                    <field name="line_ids">
                        <tree editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="block_kind"/>
                            <field name="section_id"
                                   attrs="{'required': [('block_kind', '=', 'static')],
                                           'readonly': [('block_kind', '!=', 'static')]}"
                                   options="{'no_create': True, 'no_create_edit': True}"/>
                        </tree>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_proposal_template" model="ir.actions.act_window">
        <field name="name">Templates de Proposta</field>
        <field name="res_model">afr.proposal.template</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
