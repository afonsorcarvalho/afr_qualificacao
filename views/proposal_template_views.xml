<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_proposal_template_tree" model="ir.ui.view">
        <field name="name">afr.proposal.template.tree</field>
        <field name="model">afr.proposal.template</field>
        <field name="arch" type="xml">
            <tree string="Templates de Proposta">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <record id="view_proposal_template_form" model="ir.ui.view">
        <field name="name">afr.proposal.template.form</field>
        <field name="model">afr.proposal.template</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <separator string="Blocos da Proposta (na ordem de impressão)"/>
                    <field name="line_ids">
                        <tree editable="bottom">
                            <field name="template_id" invisible="1"/>
                            <field name="sequence" widget="handle"/>
                            <field name="display_number" string="Nº" readonly="1"/>
                            <field name="show_number" widget="boolean_toggle"/>
                            <field name="show_title" widget="boolean_toggle"/>
                            <field name="title"
                                   placeholder="(usa nome da seção / rótulo do tipo)"/>
                            <field name="block_kind"/>
                            <field name="parent_id"
                                   domain="[('template_id','=',parent.id),('id','!=',id)]"
                                   options="{'no_create': True, 'no_create_edit': True}"/>
                            <field name="display_label" string="Conteúdo" readonly="1"/>
                            <field name="section_id"
                                   optional="hide"
                                   attrs="{'required': [('block_kind', '=', 'static')],
                                           'readonly': [('block_kind', '!=', 'static')]}"
                                   options="{'no_create': True, 'no_create_edit': True}"/>
                            <field name="page_break" widget="boolean_toggle"/>
                            <button name="action_edit_template_line"
                                    type="object"
                                    string="Editar"
                                    icon="fa-pencil"
                                    class="btn-link"/>
                        </tree>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <!-- F9.2 — form modal da linha (botão Editar em template dinâmico) -->
    <record id="view_proposal_template_line_form" model="ir.ui.view">
        <field name="name">afr.proposal.template.line.form</field>
        <field name="model">afr.proposal.template.line</field>
        <field name="arch" type="xml">
            <form string="Linha do Template">
                <sheet>
                    <group>
                        <group>
                            <field name="template_id" readonly="1"/>
                            <field name="block_kind"/>
                            <field name="title"/>
                            <field name="parent_id"
                                   domain="[('template_id','=',template_id),('id','!=',id)]"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                            <field name="show_number"/>
                            <field name="show_title"/>
                            <field name="page_break"/>
                            <field name="section_id"
                                   attrs="{'required': [('block_kind','=','static')],
                                           'readonly': [('block_kind','!=','static')]}"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button string="Salvar e Fechar"
                            class="btn-primary" special="save"/>
                    <button string="Descartar"
                            class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- F9.1.x — tree standalone para o popup "Pesquisar mais" do parent_id -->
    <record id="view_proposal_template_line_tree" model="ir.ui.view">
        <field name="name">afr.proposal.template.line.tree</field>
        <field name="model">afr.proposal.template.line</field>
        <field name="arch" type="xml">
            <tree string="Linhas do Template" create="false" edit="false">
                <field name="template_id"/>
                <field name="display_number" string="Nº"/>
                <field name="block_kind"/>
                <field name="display_label" string="Conteúdo"/>
            </tree>
        </field>
    </record>

    <record id="action_proposal_template" model="ir.actions.act_window">
        <field name="name">Templates de Proposta</field>
        <field name="res_model">afr.proposal.template</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
