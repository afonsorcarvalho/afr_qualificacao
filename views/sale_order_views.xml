<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit form sale.order: botão configurador + stat buttons + colunas linhas -->
    <record id="view_sale_order_form_inherit_qualificacao" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.qualificacao</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <xpath expr="//header/button[@name='action_quotation_send']" position="before">
                <button name="action_open_configurator"
                        string="Configurar Qualificações"
                        type="object"
                        class="oe_highlight"
                        attrs="{'invisible': ['|', ('state','not in',['draft','sent']), ('partner_id','=',False)]}"/>
            </xpath>

            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_qualificacoes"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-tasks"
                        attrs="{'invisible': [('qualificacao_count','=',0)]}">
                    <field name="qualificacao_count" widget="statinfo" string="Qualificações"/>
                </button>
                <button name="action_view_qualificacao_os"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-clipboard"
                        attrs="{'invisible': [('qualificacao_os_count','=',0)]}">
                    <field name="qualificacao_os_count" widget="statinfo" string="OS Qualif"/>
                </button>
                <button name="action_view_engc_os"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-wrench"
                        attrs="{'invisible': [('engc_os_count','=',0)]}">
                    <field name="engc_os_count" widget="statinfo" string="OSs (legacy)"/>
                </button>
            </xpath>

            <!-- Esconde page "Order Lines" padrão — substituída pelas 3 abas custom abaixo -->
            <xpath expr="//page[@name='order_lines']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- has_qualif_lines: campo invisível necessário para o attrs do qualif_subtotals_html -->
            <xpath expr="//field[@name='order_line']" position="after">
                <field name="has_qualif_lines" invisible="1"/>
            </xpath>

            <!-- Subtotais por equipamento: lado direito (sale_total group), acima do tax_totals -->
            <xpath expr="//group[@name='sale_total']/field[@name='tax_totals']" position="before">
                <field name="qualif_subtotals_html"
                       nolabel="1"
                       readonly="1"
                       colspan="2"
                       attrs="{'invisible': [('has_qualif_lines','=',False)]}"/>
            </xpath>

            <!-- 3 abas custom inseridas ANTES da page order_lines padrão -->
            <xpath expr="//page[@name='order_lines']" position="before">
                <page string="Linhas (Comercial)" name="qualif_comercial">
                    <field name="regular_line_ids" widget="section_and_note_one2many">
                        <tree editable="bottom">
                            <control>
                                <create name="add_product" string="Adicionar produto"/>
                                <create name="add_section" string="Adicionar seção"
                                        context="{'default_display_type': 'line_section'}"/>
                                <create name="add_note" string="Adicionar nota"
                                        context="{'default_display_type': 'line_note'}"/>
                            </control>
                            <field name="sequence" widget="handle"/>
                            <field name="display_type" invisible="1"/>
                            <field name="company_id" invisible="1"/>
                            <field name="product_uom_category_id" invisible="1"/>
                            <field name="product_id"
                                   attrs="{'required': [('display_type','=',False)]}"/>
                            <field name="name" widget="section_and_note_text"/>
                            <field name="product_uom_qty" optional="show"/>
                            <field name="product_uom"
                                   groups="uom.group_uom" optional="hide"
                                   attrs="{'required': [('display_type','=',False)]}"/>
                            <field name="price_unit"/>
                            <field name="discount" string="Desc.%" optional="hide"/>
                            <field name="tax_id" widget="many2many_tags" optional="hide"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="price_subtotal" widget="monetary"/>
                        </tree>
                    </field>
                    <field name="qualif_subtotals_html" nolabel="1" readonly="1"
                           attrs="{'invisible': [('has_qualif_lines','=',False)]}"/>
                </page>

                <page string="Opcionais" name="qualif_opcionais">
                    <field name="optional_line_ids"
                           context="{'default_is_proposal_optional': 1}">
                        <tree editable="bottom">
                            <field name="is_proposal_optional" invisible="1"/>
                            <field name="sequence" widget="handle"/>
                            <field name="display_type" invisible="1"/>
                            <field name="company_id" invisible="1"/>
                            <field name="product_uom_category_id" invisible="1"/>
                            <field name="product_id" attrs="{'required': [('display_type','=',False)]}"/>
                            <field name="name"/>
                            <field name="optional_qty" string="Qtd Opc."/>
                            <field name="price_unit"/>
                            <field name="optional_accepted" string="Aceito"
                                   widget="boolean_toggle"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="price_subtotal" widget="monetary"/>
                        </tree>
                    </field>
                    <field name="qualif_subtotals_html" nolabel="1" readonly="1"
                           attrs="{'invisible': [('has_qualif_lines','=',False)]}"/>
                </page>

                <page string="Detalhes Técnicos" name="qualif_tecnico"
                      attrs="{'invisible': [('has_qualif_lines','=',False)]}">
                    <field name="qualif_tecnico_html" nolabel="1" readonly="1"/>
                </page>
            </xpath>

            <!-- F8.2 — Proposta LEGO: aba de montagem de blocos da cotação (ao final) -->
            <xpath expr="//notebook" position="inside">
                <page string="Proposta (Blocos)" name="proposal_blocks">
                    <group>
                        <group>
                            <field name="proposal_template_id"
                                   options="{'no_create': True}"/>
                        </group>
                    </group>
                    <button name="action_reload_proposal_blocks"
                            type="object"
                            string="Carregar / Recarregar Blocos do Template"
                            class="btn-secondary"
                            confirm="Recarregar descarta as edições feitas nos blocos desta proposta. Continuar?"/>
                    <field name="proposal_block_ids">
                        <tree editable="bottom">
                            <field name="sale_order_id" invisible="1"/>
                            <field name="sequence" widget="handle"/>
                            <field name="display_number" string="Nº" readonly="1"/>
                            <field name="included" widget="boolean_toggle"/>
                            <field name="show_number" widget="boolean_toggle"/>
                            <field name="show_title" widget="boolean_toggle"/>
                            <field name="title"/>
                            <field name="block_kind"/>
                            <field name="parent_id"
                                   domain="[('sale_order_id','=',parent.id),('id','!=',id)]"
                                   options="{'no_create': True, 'no_create_edit': True}"/>
                            <field name="display_label" string="Conteúdo" readonly="1"/>
                            <field name="section_id" optional="hide"/>
                            <field name="page_break" widget="boolean_toggle"/>
                            <button name="action_edit_block" type="object"
                                    string="Editar" icon="fa-pencil"
                                    class="btn-link"/>
                        </tree>
                        <form>
                            <field name="sale_order_id" invisible="1"/>
                            <group>
                                <group>
                                    <field name="block_kind"/>
                                    <field name="title"/>
                                    <field name="parent_id"/>
                                    <field name="show_number"/>
                                    <field name="show_title"/>
                                </group>
                                <group>
                                    <field name="included"/>
                                    <field name="page_break"/>
                                    <field name="section_id" readonly="1"/>
                                </group>
                            </group>
                            <separator string="Conteúdo (aceita {{ expressões }})"/>
                            <field name="body" options="{'codeview': True}"/>
                        </form>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Esconde aba "Optional Products" do sale_management — não usada neste fluxo. -->
    <record id="view_sale_order_form_hide_optional_products" model="ir.ui.view">
        <field name="name">sale.order.form.hide.optional.products</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale_management.sale_order_form_quote"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='optional_products']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>
</odoo>
