<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit form sale.order: botão configurador + stat buttons + colunas linhas -->
    <record id="view_sale_order_form_inherit_qualificacao" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.qualificacao</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <xpath expr="//header/button[@name='action_quotation_send']" position="before">
                <button name="action_open_configurator"
                        string="Configurar Qualificações"
                        type="object"
                        class="oe_highlight"
                        attrs="{'invisible': ['|', ('state','not in',['draft','sent']), ('partner_id','=',False)]}"/>
            </xpath>

            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_qualificacoes"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-tasks"
                        attrs="{'invisible': [('qualificacao_count','=',0)]}">
                    <field name="qualificacao_count" widget="statinfo" string="Qualificações"/>
                </button>
                <button name="action_view_engc_os"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-wrench"
                        attrs="{'invisible': [('engc_os_count','=',0)]}">
                    <field name="engc_os_count" widget="statinfo" string="OSs"/>
                </button>
            </xpath>

            <xpath expr="//field[@name='order_line']/tree/field[@name='product_id']" position="after">
                <field name="is_qualificacao_managed" optional="hide"/>
                <field name="qualification_type" optional="show"/>
                <field name="equipment_id" optional="show"/>
                <field name="cycle_type_id" optional="hide"/>
                <field name="malha_type_id" optional="hide"/>
            </xpath>
        </field>
    </record>
</odoo>
