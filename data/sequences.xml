<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- Sequence: OS de Qualificação -->
    <record id="seq_afr_qualificacao_os" model="ir.sequence">
        <field name="name">OS de Qualificação</field>
        <field name="code">afr.qualificacao.os.sequence</field>
        <field name="prefix">QOS</field>
        <field name="padding">5</field>
        <field name="implementation">no_gap</field>
        <field name="company_id" eval="False"/>
    </record>

    <!-- Sequence: Relatório parcial de OS -->
    <record id="seq_afr_qualificacao_os_relatorio" model="ir.sequence">
        <field name="name">Relatório parcial OS Qualificação</field>
        <field name="code">afr.qualificacao.os.relatorio.sequence</field>
        <field name="prefix">RQOS</field>
        <field name="padding">5</field>
        <field name="implementation">no_gap</field>
        <field name="company_id" eval="False"/>
    </record>

</odoo>
