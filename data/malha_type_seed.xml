<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!--
        F8.9 — Seed de malhas comuns (Calibração) por categoria de
        equipamento. Reusa product genérico de calibração; cliente
        ajusta preço no orçamento. noupdate="1": customizável.
    -->

    <!-- Produto serviço genérico de calibração de malha -->
    <record id="product_malha_calibracao" model="product.product">
        <field name="name">Calibração de Malha</field>
        <field name="type">service</field>
        <field name="detailed_type">service</field>
        <field name="sale_ok" eval="True"/>
        <field name="purchase_ok" eval="False"/>
        <field name="list_price">0.0</field>
    </record>

    <!-- Malha de Temperatura — aplica-se à maioria dos equipamentos -->
    <record id="malha_temperatura" model="afr.qualificacao.malha.type">
        <field name="name">Malha de Temperatura</field>
        <field name="code">MLH-TEMP</field>
        <field name="product_id" ref="product_malha_calibracao"/>
        <field name="sensor_kind_id" ref="sensor_kind_temperature"/>
        <field name="sequence">10</field>
        <field name="estimated_hours">4.0</field>
    </record>

    <!-- Malha de Pressão — autoclaves -->
    <record id="malha_pressao" model="afr.qualificacao.malha.type">
        <field name="name">Malha de Pressão</field>
        <field name="code">MLH-PRESS</field>
        <field name="product_id" ref="product_malha_calibracao"/>
        <field name="sensor_kind_id" ref="sensor_kind_pressure"/>
        <field name="sequence">20</field>
        <field name="estimated_hours">4.0</field>
    </record>

    <!-- Malha de Umidade — autoclave gás -->
    <record id="malha_umidade" model="afr.qualificacao.malha.type">
        <field name="name">Malha de Umidade</field>
        <field name="code">MLH-HUM</field>
        <field name="product_id" ref="product_malha_calibracao"/>
        <field name="sensor_kind_id" ref="sensor_kind_humidity"/>
        <field name="sequence">30</field>
        <field name="estimated_hours">4.0</field>
    </record>

</odoo>
