<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!--
        F8.1 — Catálogo inicial de serviços opcionais/extras da proposta.
        Cria produtos de serviço dedicados + os opcionais que os referenciam.
        noupdate="1": cliente ajusta preços/produtos sem perder em upgrade.
    -->

    <!-- Produtos de serviço dedicados aos opcionais -->
    <record id="product_proposal_folder" model="product.product">
        <field name="name">Pasta Impressa + Postagem</field>
        <field name="type">service</field>
        <field name="detailed_type">service</field>
        <field name="sale_ok" eval="True"/>
        <field name="purchase_ok" eval="False"/>
        <field name="list_price">150.0</field>
    </record>

    <record id="product_proposal_travel" model="product.product">
        <field name="name">Despesas de Viagem (estimativa)</field>
        <field name="type">service</field>
        <field name="detailed_type">service</field>
        <field name="sale_ok" eval="True"/>
        <field name="purchase_ok" eval="False"/>
        <field name="list_price">1095.0</field>
    </record>

    <record id="product_proposal_extra_day" model="product.product">
        <field name="name">Diária Técnica Adicional</field>
        <field name="type">service</field>
        <field name="detailed_type">service</field>
        <field name="sale_ok" eval="True"/>
        <field name="purchase_ok" eval="False"/>
        <field name="list_price">1000.0</field>
    </record>

    <!-- Opcionais -->
    <record id="proposal_optional_folder" model="afr.proposal.optional">
        <field name="code">OPT-PASTA</field>
        <field name="name">Pasta impressa em couché personalizada (envio via SEDEX)</field>
        <field name="kind">folder</field>
        <field name="product_id" ref="product_proposal_folder"/>
        <field name="default_price">150.0</field>
        <field name="default_qty">1.0</field>
        <field name="sequence">10</field>
    </record>

    <record id="proposal_optional_travel" model="afr.proposal.optional">
        <field name="code">OPT-VIAGEM</field>
        <field name="name">Despesas de viagem da equipe técnica (hotel, passagens, transfer, refeições)</field>
        <field name="kind">travel</field>
        <field name="product_id" ref="product_proposal_travel"/>
        <field name="default_price">1095.0</field>
        <field name="default_qty">1.0</field>
        <field name="sequence">20</field>
    </record>

    <record id="proposal_optional_extra_day" model="afr.proposal.optional">
        <field name="code">OPT-DIARIA</field>
        <field name="name">Diária técnica adicional (por dia de trabalho excedente)</field>
        <field name="kind">extra_day</field>
        <field name="product_id" ref="product_proposal_extra_day"/>
        <field name="default_price">1000.0</field>
        <field name="default_qty">1.0</field>
        <field name="sequence">30</field>
    </record>

</odoo>
